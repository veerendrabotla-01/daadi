# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: The secure base URL of your Supabase project instance.
# Users configure this via the Secrets panel in the AI Studio UI.
SUPABASE_URL=SUPABASE_URL_PLACEHOLDER

# SUPABASE_ANON_KEY: The public client api key for your Supabase project instance.
# Users configure this via the Secrets panel in the AI Studio UI.
SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_PLACEHOLDER

# PIESOCKET_API_KEY: Optional PieSocket API key for premium/dedicated real-time channels.
PIESOCKET_API_KEY=PIESOCKET_API_KEY_PLACEHOLDER

# PIESOCKET_CLUSTER_ID: The cluster region (e.g., free.blr2) for your PieSocket instance.
PIESOCKET_CLUSTER_ID=free.blr2

# PIESOCKET_API_SECRET: The secret key for PieSocket server-to-server actions (if needed).
PIESOCKET_API_SECRET=PIESOCKET_API_SECRET_PLACEHOLDER
